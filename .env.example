# GrowthPilot Agent environment variables

# LLM Configuration
GPA_LLM_PROVIDER=openai          # openai / deepseek / local
GPA_LLM_MODEL=gpt-4o
GPA_LLM_API_KEY=your-api-key-here
GPA_LLM_BASE_URL=                # Optional: custom endpoint
GPA_LLM_TEMPERATURE=0.1

# Fallback model
GPA_FALLBACK_PROVIDER=deepseek
GPA_FALLBACK_MODEL=deepseek-chat

# Model Tier Configuration
FAST_PROVIDER=deepseek
FAST_MODEL=deepseek-chat
FAST_TEMPERATURE=0.3

DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_TEMPERATURE=0.5

POWER_PROVIDER=openai
POWER_MODEL=gpt-4o
POWER_TEMPERATURE=0.7

# Memory System
MEMORY_BASE_PATH=./data/memory

# Retry Configuration
MAX_RETRIES=3
RETRY_MIN_WAIT=1
RETRY_MAX_WAIT=10

# General
GPA_LOG_LEVEL=INFO
GPA_DATA_DIR=data/
GPA_OUTPUT_DIR=reports/
