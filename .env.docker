# ── Database ──
DB_URL=postgresql+asyncpg://gpa:gpa@db:5432/growth_pilot
DB_USER=gpa
DB_PASSWORD=gpa
DB_NAME=growth_pilot

# ── LLM ──
GPA_LLM_PROVIDER=openai
GPA_LLM_MODEL=gpt-4o-mini
GPA_LLM_API_KEY=your-api-key-here

# ── Auth ──
JWT_SECRET=change-me-in-production

# ── General ──
GPA_LOG_LEVEL=INFO
GPA_DEMO_MODE=false
